{
  "name": "dqsync-agent",
  "version": "1.0.22",
  "description": "DQSync Agent — automatic heat advancement from Meet Maestro",
  "author": "Stroke & Turn",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "generate-tray-icon": "node scripts/generate-tray-icon.js",
    "build": "npm run generate-tray-icon && electron-builder --win --x64",
    "build-mac": "electron-builder --mac"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "electron-updater": "^6.8.9",
    "firebase": "^10.12.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0"
  },
  "build": {
    "appId": "com.dqsync.agent",
    "productName": "DQSync Agent",
    "icon": "build/icon.ico",
    "win": {
      "target": "nsis",
      "requestedExecutionLevel": "asInvoker",
      "artifactName": "DQSync-Agent-Setup.exe",
      "sign": null
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "include": "build/installer.nsh"
    },
    "publish": {
      "provider": "github",
      "owner": "freydonald-spec",
      "repo": "stroke-turn-agent"
    }
  }
}
