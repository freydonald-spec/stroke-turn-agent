{
  "name": "stroke-turn-agent",
  "version": "1.0.0",
  "description": "Stroke & Turn Meet Agent — auto-advances heats from Meet Maestro",
  "author": "Stroke & Turn",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "build-mac": "electron-builder --mac"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "firebase": "^10.12.0"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0"
  },
  "build": {
    "appId": "com.strokeandturn.agent",
    "productName": "Stroke & Turn Agent",
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true
    }
  }
}